# 企业微信配置
# 企业ID：登录企微管理后台 → 我的企业 → 企业信息 → 企业ID
CORPID=your_corpid_here
# 应用密钥：应用管理 → 自建应用 → 详情页 → Secret
CORPSECRET=your_corpsecret_here
# 智能表格文档ID：打开智能表格 → URL中 docid 参数
DOCID=your_docid_here

# 服务端口
PORT=3000

# 温度告警阈值（摄氏度）
TEMP_MIN=2
TEMP_MAX=8

# 数据刷新建议间隔（秒），前端按此轮询
REFRESH_INTERVAL=30

# ====== 企业微信回调配置（用于配置可信IP前置条件） ======
# 在企微管理后台 → 自建应用 → 接收消息 → 设置API接收
# Token: 自定义英文/数字，不超过32位（用于签名验证）
WECOM_TOKEN=your_token_here
# EncodingAESKey: 自定义43位英文/数字（用于消息加解密）→ 点击“随机生成”即可
WECOM_ENCODING_AES_KEY=your_43char_aes_key_here
